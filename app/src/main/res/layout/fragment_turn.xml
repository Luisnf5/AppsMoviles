<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#140B15">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Botón cerrar -->
            <FrameLayout
                android:id="@+id/btnCloseTurn"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="end"
                android:background="@drawable/bg_home_social_circle"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/cd_close"
                    android:src="@drawable/ic_close"
                    app:tint="#66FFFFFF" />
            </FrameLayout>

            <Space
                android:layout_width="wrap_content"
                android:layout_height="56dp" />

            <!-- Icono -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_turn_icon_circle">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/turn_icon_cd"
                    android:src="@drawable/ic_hand_metal"
                    app:tint="#FF2D85" />
            </FrameLayout>

            <Space
                android:layout_width="wrap_content"
                android:layout_height="24dp" />

            <!-- Cabecera -->
            <TextView
                android:id="@+id/tvTurnLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.8"
                android:letterSpacing="0.35"
                android:text="@string/turn_label"
                android:textAllCaps="true"
                android:textColor="#FF2D85"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="20dp" />

            <!-- Nombre jugador -->
            <TextView
                android:id="@+id/tvCurrentPlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CARLOS"
                android:textAllCaps="true"
                android:textColor="#FB923C"
                android:textSize="56sp"
                android:textStyle="bold|italic"
                android:fontFamily="sans-serif-black" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="28dp" />

            <!-- Texto -->
            <TextView
                android:id="@+id/tvPassDevice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/turn_pass_device"
                android:textColor="#99FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="20dp" />

            <!-- Puntitos -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_players_add_button"
                    android:alpha="0.35" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_players_add_button"
                    android:alpha="0.6" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_players_add_button"
                    android:alpha="1.0" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Glow + botón -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="8dp"
                    android:layout_marginBottom="8dp"
                    android:alpha="0.55"
                    android:background="@drawable/bg_turn_ready_glow" />

                <LinearLayout
                    android:id="@+id/btnReady"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_turn_ready_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/turn_ready"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black" />

                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>