<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#140B15">

        <LinearLayout
            android:id="@+id/homeContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <Space
                android:layout_width="wrap_content"
                android:layout_height="8dp" />

            <FrameLayout
                android:layout_width="192dp"
                android:layout_height="192dp"
                android:layout_gravity="center_horizontal">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_home_logo_glow" />

                <FrameLayout
                    android:layout_width="192dp"
                    android:layout_height="192dp"
                    android:background="@drawable/bg_home_logo_circle">

                    <ImageView
                        android:id="@+id/ivMartini"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_logo_copa"
                        android:src="@drawable/ic_martini"
                        app:tint="@android:color/white" />

                    <ImageView
                        android:id="@+id/ivZap"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="44dp"
                        android:layout_marginTop="18dp"
                        android:contentDescription="@string/cd_logo_rayo"
                        android:src="@drawable/ic_zap"
                        app:tint="#FACC15" />
                </FrameLayout>
            </FrameLayout>

            <Space
                android:layout_width="wrap_content"
                android:layout_height="48dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvBrandTrago"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_brand_trago"
                        android:textAllCaps="true"
                        android:textColor="@android:color/white"
                        android:textSize="34sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tvBrandMaestro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_brand_maestro"
                        android:textAllCaps="true"
                        android:textColor="#FF2D85"
                        android:textSize="34sp"
                        android:textStyle="bold|italic"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:alpha="0.9"
                    android:letterSpacing="0.2"
                    android:text="@string/home_subtitle"
                    android:textAllCaps="true"
                    android:textColor="#FF2D85"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <Space
                android:layout_width="wrap_content"
                android:layout_height="40dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="72dp"
                android:background="@drawable/bg_home_start_button"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:text="@string/home_start"
                android:textAllCaps="true"
                android:textColor="#140B15"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="999dp" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="44dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/tvShareTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.8"
                    android:letterSpacing="0.2"
                    android:text="@string/home_share"
                    android:textAllCaps="true"
                    android:textColor="#FF2D85"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <FrameLayout
                        android:id="@+id/btnInstagram"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_home_social_circle"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/cd_instagram"
                            android:src="@drawable/ic_instagram"
                            app:tint="@android:color/white"
                            android:alpha="0.8" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/btnFacebook"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_home_social_circle"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/cd_facebook"
                            android:src="@drawable/ic_facebook"
                            app:tint="@android:color/white"
                            android:alpha="0.8" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/btnTwitter"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_home_social_circle"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:contentDescription="@string/cd_twitter"
                            android:src="@drawable/ic_twitter"
                            app:tint="@android:color/white"
                            android:alpha="0.8" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="@string/home_terms"
                        android:textColor="#FF2D85"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"
                        android:alpha="0.4"
                        android:text="—"
                        android:textColor="#FF2D85"
                        android:textSize="9sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.4"
                        android:text="@string/home_privacy"
                        android:textColor="#FF2D85"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCopyright"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:alpha="0.4"
                    android:letterSpacing="0.12"
                    android:text="@string/home_copyright"
                    android:textAllCaps="true"
                    android:textColor="#FF2D85"
                    android:textSize="9sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>