<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pulsado -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#E02674"/>
            <corners android:radius="36dp"/>
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <shape>
            <solid android:color="#FF2D85"/>
            <corners android:radius="36dp"/>
        </shape>
    </item>

</selector>